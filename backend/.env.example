# SQLite (base de datos local)
SQLITE_PATH=./data/gestdelfin.db

# Autenticación (clave para firmar los JWT) — usa una cadena larga y secreta
JWT_SECRET=cambia-esta-clave-por-una-larga-y-secreta

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude) — bot del sistema
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# Servidor
PORT=3001

# Frontend origin (para CORS)
FRONTEND_URL=http://localhost:3000
